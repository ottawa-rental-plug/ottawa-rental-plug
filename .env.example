# ORP Environment Configuration
# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local to git (it's in .gitignore)

# ============================================================================
# SUPABASE DATABASE & AUTH
# ============================================================================
SUPABASE_URL=https://lvmsajsvkmwejggecehp.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ============================================================================
# SINGLE KEY SCREENING
# ============================================================================
SINGLEKEY_API_TOKEN=your_singlekey_api_token
SINGLEKEY_CLIENT_ID=your_singlekey_client_id
SINGLEKEY_WEBHOOK_SECRET=your_singlekey_webhook_secret

# ============================================================================
# NETLIFY
# ============================================================================
NETLIFY_API_TOKEN=your_netlify_api_token
NETLIFY_FORM_ID=your_netlify_form_id
NETLIFY_LANDLORD_FORM_ID=your_netlify_landlord_form_id

# ============================================================================
# ADMIN & SECURITY
# ============================================================================
DASHBOARD_PASSWORD=your_dashboard_password
ADMIN_EMAIL=cyrilrentsottawa@gmail.com

# ============================================================================
# SYNDICATION - REALTOR.CA (DDF® Web API)
# ============================================================================
# Get from: https://developer.realtor.ca/
REALTOR_CA_CLIENT_ID=your_realtor_ca_client_id
REALTOR_CA_CLIENT_SECRET=your_realtor_ca_client_secret
REALTOR_CA_API_URL=https://ddfapi.realtor.ca
REALTOR_CA_WEBHOOK_SECRET=your_realtor_ca_webhook_secret

# ============================================================================
# SYNDICATION - KIJIJI (via Apify)
# ============================================================================
KIJIJI_USERNAME=your_kijiji_username
KIJIJI_PASSWORD=your_kijiji_password
KIJIJI_WEBHOOK_SECRET=your_kijiji_webhook_secret

# Apify Configuration (for Kijiji posting automation)
APIFY_API_TOKEN=your_apify_api_token
APIFY_KIJIJI_ACTOR_ID=apify/kijiji-post-lister

# ============================================================================
# SYNDICATION - AIRBNB
# ============================================================================
AIRBNB_API_KEY=your_airbnb_api_key
AIRBNB_CLIENT_ID=your_airbnb_client_id
AIRBNB_API_URL=https://api.airbnb.com/v2
AIRBNB_WEBHOOK_SECRET=your_airbnb_webhook_secret

# ============================================================================
# CDN & IMAGE OPTIMIZATION
# ============================================================================
CDN_BASE_URL=https://cdn.ottawarentalplug.com
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ZONE_ID=your_cloudflare_zone_id
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id

# Image Processing Settings
IMAGE_MAX_SIZE=10485760                # 10MB in bytes
IMAGE_FORMATS=jpg,jpeg,png,webp
IMAGE_QUALITY=85                       # 1-100, default 85
THUMBNAIL_WIDTH=300
THUMBNAIL_HEIGHT=225

# ============================================================================
# SYNDICATION BEHAVIOR
# ============================================================================
SYNDICATION_BATCH_SIZE=50              # How many listings to sync per job
SYNDICATION_RETRY_ATTEMPTS=3           # Number of retries on failure
SYNDICATION_RETRY_DELAY_MS=5000        # Milliseconds to wait between retries
SYNDICATION_ENABLED=true               # Master switch for all syndication

# ============================================================================
# NOTIFICATIONS
# ============================================================================
NTFY_TOPIC=orp-alerts
NTFY_BASE_URL=https://ntfy.sh

# ============================================================================
# EMAIL (Phase 8+)
# ============================================================================
# SENDGRID_API_KEY=your_sendgrid_api_key
# SENDGRID_FROM_EMAIL=noreply@ottawarentalplug.com
# MAILGUN_API_KEY=your_mailgun_api_key
# MAILGUN_DOMAIN=mail.ottawarentalplug.com

# ============================================================================
# SMS (Phase 8+)
# ============================================================================
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_PHONE_NUMBER=+1613555xxxx

# ============================================================================
# MONITORING & LOGGING
# ============================================================================
LOG_LEVEL=info                         # debug, info, warn, error
SENTRY_DSN=                            # Optional: error tracking
SLACK_WEBHOOK=                         # Optional: notifications to Slack

# ============================================================================
# DEVELOPMENT
# ============================================================================
NODE_ENV=development                   # development, production
DEBUG=false                            # Enable debug logging
